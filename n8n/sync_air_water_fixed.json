            "parameters": {
                "jsCode": "// 從 Webhook body 取得資料\nconst body = $input.first().json.body;\nconst airRecords = body.airRecords || [];\nconst waterRecords = body.waterRecords || [];\nconst sheetName = body.sheetName || 'Unknown';\n\nconsole.log(`📥 收到資料，來自工作表：${sheetName}`);\nconsole.log(`   空污：${airRecords.length} 筆`);\nconsole.log(`   水污：${waterRecords.length} 筆`);\n\n// 日期轉換：把各種格式轉成 \"115/10/17\" 民國格式\nfunction convertToMinguo(dateStr) {\n  if (!dateStr) return '';\n  const str = String(dateStr).trim();\n  \n  // 格式1: 0119-10-17T15:54:00.000Z (ISO with ROC year prefix)\n  const isoMatch = str.match(/^0?(\\d{2,3})-(\\d{2})-(\\d{2})/);\n  if (isoMatch) {\n    const year = isoMatch[1].replace(/^0+/, '');\n    return `${year}/${isoMatch[2]}/${isoMatch[3]}`;\n  }\n  \n  // 格式2: 119/10/17 或 0119/10/17\n  const rocMatch = str.match(/^0?(\\d{2,3})\\/(\\d{1,2})\\/(\\d{1,2})/);\n  if (rocMatch) {\n    const year = rocMatch[1].replace(/^0+/, '');\n    return `${year}/${rocMatch[2].padStart(2,'0')}/${rocMatch[3].padStart(2,'0')}`;\n  }\n  \n  // 格式3: 2026-10-17 (西元 ISO)\n  const westMatch = str.match(/^(\\d{4})-(\\d{2})-(\\d{2})/);\n  if (westMatch) {\n    const rocYear = parseInt(westMatch[1]) - 1911;\n    return `${rocYear}/${westMatch[2]}/${westMatch[3]}`;\n  }\n  \n  return str; // 回傳原始值\n}\n\n// 準備輸出：分別處理空污和水污\nconst output = [];\n\n// 處理空污\nairRecords.forEach(r => {\n  output.push({\n    type: 'air',\n    ems_no: r.ems_no || '',\n    county: r.county || '',\n    company_name: r.company_name || '',\n    address: r.address || '',\n    category: r.category || '操作',\n    expiry_date: convertToMinguo(r.expiry_date),\n    uniformno: r.uniformno || ''\n  });\n});\n\n// 處理水污\nwaterRecords.forEach(r => {\n  output.push({\n    type: 'water',\n    ems_no: r.ems_no || '',\n    fac_name: r.fac_name || '',\n    address: r.address || '',\n    per_edate: convertToMinguo(r.per_edate),\n    ban: r.ban || ''\n  });\n});\n\nif (output.length === 0) {\n  throw new Error('沒有收到任何資料');\n}\n\nreturn output.map(item => ({ json: item }));"
            },
