        {
            "parameters": {
                "jsCode": "// 合併統計結果\nconst items = $input.all();\nlet airSuccess = 0, airError = 0;\nlet waterSuccess = 0, waterError = 0;\n\nitems.forEach(item => {\n  if (item.json.type === 'air') {\n    airSuccess = item.json.success || 0;\n    airError = item.json.error || 0;\n  } else if (item.json.type === 'water') {\n    waterSuccess = item.json.success || 0;\n    waterError = item.json.error || 0;\n  }\n});\n\nreturn [{\n  json: {\n    success: true,\n    message: `✅ 同步完成！`,\n    air: { success: airSuccess, error: airError },\n    water: { success: waterSuccess, error: waterError },\n    total: airSuccess + waterSuccess,\n    timestamp: new Date().toISOString()\n  }\n}];"
            },
