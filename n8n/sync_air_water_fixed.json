                "jsCode": "// 統計水污結果\nconst items = $input.all();\nconst successCount = items.filter(i => !i.json.error).length;\nconst errorCount = items.filter(i => i.json.error).length;\n\nreturn [{\n  json: {\n    type: 'water',\n    success: successCount,\n    error: errorCount\n  }\n}];"
