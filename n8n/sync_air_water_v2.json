        {
            "parameters": {
                "jsCode": "// Split Out 後，每個 item 已經是單筆 record\nconst items = $input.all();\n\n// 民國日期轉 ISO 西元格式\nfunction convertToISO(dateStr) {\n  if (!dateStr) return null;\n  const str = String(dateStr).trim();\n  \n  // 格式1: 0119-10-17T15:54:00.000Z\n  const isoMatch = str.match(/^0?(\\d{2,3})-(\\d{2})-(\\d{2})/);\n  if (isoMatch) {\n    const rocYear = parseInt(isoMatch[1]);\n    const westYear = rocYear + 1911;\n    return `${westYear}-${isoMatch[2]}-${isoMatch[3]}`;\n  }\n  \n  // 格式2: 117/02/29\n  const rocMatch = str.match(/^0?(\\d{2,3})\\/(\\d{1,2})\\/(\\d{1,2})/);\n  if (rocMatch) {\n    const rocYear = parseInt(rocMatch[1]);\n    const westYear = rocYear + 1911;\n    const mm = rocMatch[2].padStart(2, '0');\n    const dd = rocMatch[3].padStart(2, '0');\n    return `${westYear}-${mm}-${dd}`;\n  }\n  \n  // 格式3: 已經是 2028-02-29\n  const westMatch = str.match(/^(\\d{4})-(\\d{2})-(\\d{2})/);\n  if (westMatch) return str;\n  \n  return null;\n}\n\nreturn items.map(item => {\n  const r = item.json;\n  return {\n    json: {\n      ems_no: r.ems_no || '',\n      county: r.county || '',\n      company_name: r.company_name || '',\n      address: r.address || '',\n      category: r.category || '操作',\n      expiry_date: convertToISO(r.expiry_date),\n      uniformno: r.uniformno || ''\n    }\n  };\n});"
            },
