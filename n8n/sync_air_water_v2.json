        {
            "parameters": {
                "jsCode": "const items = $input.all();\nlet airCount = 0, waterCount = 0;\n\nitems.forEach(item => {\n  if (item.json.type === 'air') airCount = item.json.count || 0;\n  if (item.json.type === 'water') waterCount = item.json.count || 0;\n});\n\nreturn [{\n  json: {\n    success: true,\n    message: `同步完成！空污 ${airCount} 筆，水污 ${waterCount} 筆`,\n    airCount: airCount,\n    waterCount: waterCount,\n    total: airCount + waterCount,\n    timestamp: new Date().toISOString()\n  }\n}];"
            },
